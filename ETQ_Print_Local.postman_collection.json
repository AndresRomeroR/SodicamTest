    {
      "name": "Labels - Print",
      "item": [
        {
          "name": "POST /api/v1/labels/print - approved print",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lpn\": \"{{validLpn}}\",\n  \"zone\": \"ZONA-PICKING-A\",\n  \"requestedBy\": \"usuario.operacion\",\n  \"reprintReason\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/labels/print",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "labels",
                "print"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Print is approved and returns ZPL', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.isSuccessful).to.eql(true);",
                  "  pm.expect(body.result.result).to.eql('APPROVED');",
                  "  pm.expect(['PRINT', 'REPRINT']).to.include(body.result.eventType);",
                  "  pm.expect(body.result.label.lpnId).to.eql(pm.collectionVariables.get('validLpn'));",
                  "  pm.expect(body.result.label.zpl).to.be.a('string').and.include('^XA');",
                  "  pm.expect(body.result.rejectionReasons).to.eql([]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/labels/print - legacy request",
          "request": {
