        {
          "name": "GET /api/v1/labels/history - filtered by LPN",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/labels/history?identifier={{validLpn}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "labels",
                "history"
              ],
              "query": [
                {
                  "key": "identifier",
                  "value": "{{validLpn}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Filtered history returns matching events', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.result).to.be.an('array');",
                  "  if (body.result.length > 0) {",
                  "    body.result.forEach((event) => {",
                  "      pm.expect([event.lpnId, event.etqId]).to.include(pm.collectionVariables.get('validLpn'));",
                  "    });",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
